#N canvas 400 200 600 450 12;
#X obj 50 200 bang_envelope;
#X floatatom 50 250 6 0 1 0 - - - 0;
#X obj 50 150 bng 25 250 50 0 empty empty bang 0 -10 0 12 #fcfcfc #000000 #000000;
#X text 50 30 bang_envelope - Convert bangs to 0-1 envelopes for shaders;
#X text 50 60 Usage: Send a bang to trigger a 0->1->0 envelope;
#X text 50 80 Perfect for sending drum triggers to GLSL shaders;
#X text 50 280 Output: 0-1 float suitable for shader uniforms;
#X obj 200 150 nbx 5 14 1 1000 0 0 empty empty attack_ms 0 -8 0 10 #fcfcfc #000000 #000000 5 256;
#X obj 300 150 nbx 5 14 1 2000 0 0 empty empty decay_ms 0 -8 0 10 #fcfcfc #000000 #000000 300 256;
#X text 50 320 Example: Connect to [s shader_a] to send to GEM shader;
#X obj 50 350 s shader_a;
#X text 50 380 Inlets: 1=bang 2=attack(ms) 3=decay(ms);
#X connect 0 0 1 0;
#X connect 1 0 10 0;
#X connect 2 0 0 0;
#X connect 7 0 0 1;
#X connect 8 0 0 2;
